# Copy to `.env` for docker compose to auto-load it.
# Every value is optional — compose falls back to the defaults shown below.

# ── Default profile ──────────────────────────────────────────────────────────
# Picks the profile when `docker compose up` is run with no explicit --profile.
# Override per-invocation: `docker compose --profile dev up`.
COMPOSE_PROFILES=prod

# ── Image naming ─────────────────────────────────────────────────────────────
IMAGE_REPO=bmad-test
IMAGE_TAG=local

# ── Host port mappings ───────────────────────────────────────────────────────
# prod (nginx)
FRONTEND_PORT=8080
# dev (vite + tsx watch)
FRONTEND_DEV_PORT=5173
BACKEND_DEV_PORT=3000

# ── Resource caps ────────────────────────────────────────────────────────────
BACKEND_MEM_LIMIT=512m
FRONTEND_MEM_LIMIT=128m

# ── Logging ──────────────────────────────────────────────────────────────────
# Pino log level inside the backend (trace|debug|info|warn|error|fatal).
LOG_LEVEL=info
# Per-container json-file driver rotation (dropped on hosts that don't use json-file).
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# ── Naming ───────────────────────────────────────────────────────────────────
VOLUME_PREFIX=bmad-test
NETWORK_NAME=bmad-test-net
